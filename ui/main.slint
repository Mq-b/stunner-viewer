import { Button, VerticalBox, HorizontalBox, ScrollView, ListView, GroupBox, Palette } from "std-widgets.slint";
import { SpectrumChart } from "spectrum-chart.slint";

struct MetaItem {
    key: string,
    value: string,
}

struct PositionItem {
    index: int,
    name: string,
}

export component MainWindow inherits Window {
    title: "Stunner Viewer";
    preferred-width: 1100px;
    preferred-height: 700px;
    icon: @image-url("../assets/icon.svg");

    callback open-file-clicked();
    callback export-xlsx-clicked();
    callback position-selected(int);

    in property <string> current-filename;
    in property <bool> has-data: current-filename != "";
    in property <[MetaItem]> experiment-info;
    in property <[MetaItem]> instrument-info;
    in property <[PositionItem]> positions;
    in property <string> spectrum-path-commands;
    in property <string> status-message;
    in property <bool> is-loading: false;

    VerticalBox {
        // === 工具栏 ===
        Rectangle {
            height: 44px;
            background: Palette.alternate-background;
            border-width: 1px;
            border-color: Palette.border;

            HorizontalBox {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                Button {
                    text: "📂 打开文件";
                    primary: true;
                    clicked => { root.open-file-clicked(); }
                }

                Button {
                    text: "📊 导出 XLSX";
                    enabled: root.has-data;
                    clicked => { root.export-xlsx-clicked(); }
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: root.current-filename;
                    color: Palette.foreground.transparentize(40%);
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 2;
                }
            }
        }

        // === 主内容区 ===
        HorizontalBox {
            spacing: 0px;
            horizontal-stretch: 1;

            // 左侧信息面板
            Rectangle {
                width: 270px;
                background: Palette.alternate-background;
                border-width: 1px;
                border-color: Palette.border;
                vertical-stretch: 1;

                ScrollView {
                    VerticalBox {
                        spacing: 0px;
                        padding: 10px;

                        // 实验信息
                        Rectangle {
                            background: Palette.background;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.border;
                            vertical-stretch: 0;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 4px;

                                Text {
                                    text: "🧪 实验信息";
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: Palette.accent-background;
                                    height: 20px;
                                }

                                for item in root.experiment-info : Rectangle {
                                    height: 28px;
                                    horizontal-stretch: 1;

                                    HorizontalLayout {
                                        padding-left: 2px;
                                        padding-right: 2px;

                                        Text {
                                            text: item.key;
                                            color: Palette.foreground;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: item.value;
                                            font-size: 11px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            horizontal-stretch: 2;
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 10px; }

                        // 仪器信息
                        Rectangle {
                            background: Palette.background;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.border;
                            vertical-stretch: 0;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 4px;

                                Text {
                                    text: "🔬 仪器信息";
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: Palette.accent-background;
                                    height: 20px;
                                }

                                for item in root.instrument-info : Rectangle {
                                    height: 28px;
                                    horizontal-stretch: 1;

                                    HorizontalLayout {
                                        padding-left: 2px;
                                        padding-right: 2px;

                                        Text {
                                            text: item.key;
                                            color: Palette.foreground;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                        }
                                        Text {
                                            text: item.value;
                                            font-size: 11px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            horizontal-stretch: 2;
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { height: 10px; }

                        // 测量位置
                        Rectangle {
                            background: Palette.background;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Palette.border;
                            vertical-stretch: 1;
                            horizontal-stretch: 1;

                            VerticalBox {
                                padding: 10px;
                                spacing: 0px;

                                Text {
                                    text: "📍 测量位置";
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: Palette.accent-background;
                                    vertical-stretch: 0;
                                    height: 20px;
                                }

                                Rectangle { height: 6px; }

                                ListView {
                                    vertical-stretch: 1;
                                    for pos in root.positions : Rectangle {
                                        height: 28px;
                                        border-radius: 4px;
                                        background: Math.mod(pos.index, 2) == 0
                                            ? Palette.alternate-background
                                            : Palette.background;

                                        HorizontalBox {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            spacing: 8px;

                                            Text {
                                                text: pos.index;
                                                color: Palette.foreground;
                                                font-size: 10px;
                                                vertical-alignment: center;
                                                width: 28px;
                                                horizontal-alignment: right;
                                            }
                                            Text {
                                                text: pos.name;
                                                font-size: 11px;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // 右侧图表区
            SpectrumChart {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                path-commands: root.spectrum-path-commands;
            }
        }

        // === 状态栏 ===
        Rectangle {
            height: 32px;
            background: Palette.alternate-background;
            border-width: 1px;
            border-color: Palette.border;

            HorizontalBox {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 4px;
                padding-bottom: 4px;

                Text {
                    text: root.is-loading ? "正在加载..." : root.status-message;
                    color: Palette.foreground.transparentize(40%);
                    font-size: 12px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: root.has-data ? "数据已加载" : "";
                    color: Palette.foreground.transparentize(40%);
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }
    }
}
