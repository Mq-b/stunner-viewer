import { Palette } from "std-widgets.slint";

/// 光谱折线图组件
export component SpectrumChart inherits Rectangle {
    in property <string> path-commands;
    in property <string> title: "光谱数据";
    in property <string> x-axis-label: "波长 (nm)";
    in property <string> y-axis-label: "吸光度";
    in property <bool> has-data: path-commands != "";
    property <length> plot-x: 50px;
    property <length> plot-y: 40px;
    property <length> plot-w: self.width - 70px;
    property <length> plot-h: self.height - 70px;

    background: Palette.background;
    border-width: 1px;
    border-color: Palette.border;
    border-radius: 6px;
    clip: true;

    if !has-data : Text {
        text: "请打开 .bin 文件查看光谱数据";
        color: Palette.foreground.transparentize(50%);
        font-size: 14px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // 标题
    if has-data : Text {
        text: root.title;
        x: root.plot-x;
        y: 10px;
        color: #2c3e50;
        font-size: 12px;
        font-weight: 600;
    }

    // Y 轴标签
    if has-data : Text {
        text: root.y-axis-label;
        x: root.plot-x;
        y: 26px;
        color: #7f8c8d;
        font-size: 10px;
    }

    // X 轴标签
    if has-data : Text {
        text: root.x-axis-label;
        x: root.plot-x + root.plot-w / 2 - 30px;
        y: root.plot-y + root.plot-h + 30px;
        color: #7f8c8d;
        font-size: 10px;
    }

    // 图表绘制区域
    if has-data : Rectangle {
        x: root.plot-x;
        y: root.plot-y;
        width: root.plot-w;
        height: root.plot-h;
        clip: true;
        background: #fafbfc;
        border-width: 1px;
        border-color: #dfe6e9;
        border-radius: 4px;

        spectrum-path := Path {
            width: parent.width;
            height: parent.height;
            commands: root.path-commands;
            stroke-width: 1px;
            stroke: #2980b9;
            fill: transparent;
        }
    }
}
